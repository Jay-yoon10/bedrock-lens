# frontend/.env
# Copy this to .env and fill in values from your `cdk deploy` outputs
#
# Find these values in the CDK deploy output:
#   ApiUrl          → VITE_API_URL
#   UserPoolId      → VITE_COGNITO_USER_POOL_ID
#   UserPoolClientId → VITE_COGNITO_CLIENT_ID

VITE_API_URL=https://xxxxxxxxxx.execute-api.ap-southeast-2.amazonaws.com/prod
VITE_COGNITO_USER_POOL_ID=ap-southeast-2_xxxxxxxxx
VITE_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_COGNITO_REGION=ap-southeast-2
